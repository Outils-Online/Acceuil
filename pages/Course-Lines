<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>OVNI CONTROL V9</title>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Syne:wght@700;800&display=swap');

:root {
  --bg: #080c14;
  --surface: #0d1420;
  --card: #111827;
  --card2: #161f2e;
  --border: #1e2d40;
  --border2: #243346;
  --primary: #3b82f6;
  --primary-dim: rgba(59,130,246,0.15);
  --accent: #c8ff57;
  --accent-dim: rgba(200,255,87,0.12);
  --danger: #ef4444;
  --danger-dim: rgba(239,68,68,0.12);
  --success: #22c55e;
  --success-dim: rgba(34,197,94,0.12);
  --amber: #f59e0b;
  --amber-dim: rgba(245,158,11,0.12);
  --text: #f1f5f9;
  --text-muted: #64748b;
  --text-soft: #94a3b8;
  --font-display: 'Syne', sans-serif;
  --font-body: 'Space Grotesk', sans-serif;
  --radius: 14px;
  --radius-sm: 8px;
  --shadow: 0 4px 24px rgba(0,0,0,0.4);
}

* { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  font-family: var(--font-body);
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  padding-bottom: 90px;
  overflow-x: hidden;
}

/* ─── GRID NOISE BACKGROUND ─── */
body::before {
  content: '';
  position: fixed; inset: 0;
  background-image: radial-gradient(ellipse 80% 50% at 20% -20%, rgba(59,130,246,0.08) 0%, transparent 60%),
                    radial-gradient(ellipse 60% 40% at 80% 110%, rgba(200,255,87,0.05) 0%, transparent 50%);
  pointer-events: none; z-index: 0;
}

/* ─── HEADER ─── */
header {
  position: sticky; top: 0; z-index: 100;
  background: rgba(8,12,20,0.92);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--border);
  padding: 14px 16px;
}
.header-inner { display: flex; align-items: center; justify-content: space-between; }
.logo {
  font-family: var(--font-display);
  font-size: 1.1rem; font-weight: 800;
  letter-spacing: 2px;
  color: var(--text);
}
.logo span { color: var(--accent); }
.logo sub { font-size: 0.5rem; color: var(--text-muted); letter-spacing: 0; vertical-align: middle; }

.header-actions { display: flex; gap: 8px; align-items: center; }
.btn-ghost {
  background: var(--card); border: 1px solid var(--border2);
  color: var(--text-soft); padding: 7px 12px;
  border-radius: var(--radius-sm); font-size: 0.72rem; font-weight: 600;
  cursor: pointer; display: flex; align-items: center; gap: 6px;
  transition: all 0.2s;
  font-family: var(--font-body);
}
.btn-ghost:hover { border-color: var(--primary); color: var(--text); }
.btn-ghost.accent-ghost { border-color: rgba(200,255,87,0.3); color: var(--accent); }
.btn-ghost.accent-ghost:hover { background: var(--accent-dim); }

/* ─── TABS ─── */
.tab-strip {
  display: flex; gap: 4px;
  background: rgba(255,255,255,0.03);
  border: 1px solid var(--border);
  border-radius: 10px; padding: 3px;
  margin-top: 12px;
}
.tab {
  flex: 1; text-align: center;
  padding: 9px 6px;
  font-size: 0.7rem; font-weight: 700;
  letter-spacing: 0.5px;
  border-radius: 7px; cursor: pointer;
  color: var(--text-muted);
  transition: all 0.25s;
}
.tab.active {
  background: var(--primary);
  color: #fff;
  box-shadow: 0 2px 12px rgba(59,130,246,0.35);
}
.tab .badge {
  display: inline-block;
  background: rgba(255,255,255,0.2);
  border-radius: 99px;
  padding: 1px 6px; margin-left: 4px;
  font-size: 0.65rem;
}

/* ─── SECTIONS ─── */
.section { display: none; padding: 16px; animation: fadeUp 0.3s ease; }
.section.active { display: block; }
@keyframes fadeUp { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:none; } }

/* ─── CARDS ─── */
.card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 16px;
  margin-bottom: 14px;
  position: relative;
  overflow: hidden;
  transition: border-color 0.2s;
}
.card:hover { border-color: var(--border2); }
.card-title {
  font-size: 0.7rem; font-weight: 700;
  letter-spacing: 1.5px; text-transform: uppercase;
  color: var(--accent);
  display: flex; align-items: center; gap: 8px;
  margin-bottom: 14px;
}
.card-title i { font-size: 0.8rem; opacity: 0.8; }

/* ─── FORM ELEMENTS ─── */
.field-group { margin-bottom: 10px; }
.field-label { font-size: 0.68rem; color: var(--text-muted); font-weight: 600; letter-spacing: 0.5px; margin-bottom: 5px; }
input, select, textarea {
  width: 100%;
  background: var(--surface);
  border: 1px solid var(--border2);
  border-radius: var(--radius-sm);
  color: var(--text);
  padding: 10px 12px;
  font-size: 0.9rem;
  font-family: var(--font-body);
  outline: none;
  transition: border-color 0.2s, box-shadow 0.2s;
}
input:focus, select:focus { border-color: var(--primary); box-shadow: 0 0 0 3px rgba(59,130,246,0.12); }
input.error { border-color: var(--danger); box-shadow: 0 0 0 3px rgba(239,68,68,0.12); }
select option { background: var(--card); }

.row { display: flex; gap: 8px; }
.row > * { flex: 1; }

/* ─── BUTTONS ─── */
.btn {
  display: inline-flex; align-items: center; justify-content: center;
  gap: 7px; padding: 12px 16px;
  border: none; border-radius: var(--radius-sm);
  font-family: var(--font-body); font-size: 0.85rem; font-weight: 700;
  cursor: pointer; transition: all 0.2s;
  position: relative; overflow: hidden;
  letter-spacing: 0.3px;
}
.btn:active { transform: scale(0.97); }
.btn-primary { background: var(--primary); color: #fff; width: 100%; }
.btn-primary:hover { background: #2563eb; box-shadow: 0 4px 20px rgba(59,130,246,0.4); }
.btn-success { background: var(--success); color: #fff; flex: 2; }
.btn-success:hover { box-shadow: 0 4px 20px rgba(34,197,94,0.3); }
.btn-danger { background: var(--danger); color: #fff; }
.btn-danger:hover { box-shadow: 0 4px 20px rgba(239,68,68,0.3); }
.btn-neutral { background: var(--card2); border: 1px solid var(--border2); color: var(--text-soft); width: 100%; }
.btn-neutral:hover { border-color: var(--border); color: var(--text); }
.btn-icon {
  width: 36px; height: 36px; border-radius: 50%;
  border: none; cursor: pointer;
  display: inline-flex; align-items: center; justify-content: center;
  font-size: 0.8rem; transition: all 0.2s;
}
.btn-icon:active { transform: scale(0.9); }
.btn-icon-check { background: var(--success-dim); color: var(--success); border: 1px solid rgba(34,197,94,0.2); }
.btn-icon-check:hover { background: var(--success); color: #fff; }
.btn-icon-trash { background: var(--danger-dim); color: var(--danger); border: 1px solid rgba(239,68,68,0.2); }
.btn-icon-trash:hover { background: var(--danger); color: #fff; }
.btn-icon-edit { background: var(--primary-dim); color: var(--primary); border: 1px solid rgba(59,130,246,0.2); }
.btn-icon-edit:hover { background: var(--primary); color: #fff; }

/* ─── SESSION BANNER ─── */
.session-banner {
  background: linear-gradient(135deg, #0d1a30, #0a1520);
  border: 1px solid rgba(59,130,246,0.25);
  border-radius: var(--radius);
  padding: 14px 16px;
  margin-bottom: 14px;
  position: relative; overflow: hidden;
}
.session-banner::before {
  content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 3px;
  background: linear-gradient(180deg, var(--primary), var(--accent));
  border-radius: 3px;
}
.session-label { font-size: 0.62rem; font-weight: 700; letter-spacing: 1.5px; color: var(--text-muted); text-transform: uppercase; margin-bottom: 6px; }
.session-text { font-size: 0.95rem; font-weight: 700; }
.session-text .tag {
  display: inline-flex; align-items: center; gap: 4px;
  background: var(--primary-dim); border: 1px solid rgba(59,130,246,0.2);
  color: var(--primary); border-radius: 6px;
  padding: 2px 8px; font-size: 0.78rem; margin: 2px 3px 2px 0;
}
.session-tag-qty { font-weight: 900; color: var(--accent); }
.session-footer { display: flex; align-items: center; justify-content: space-between; margin-top: 10px; }
.session-cost {
  font-size: 0.8rem; color: var(--amber);
  display: flex; align-items: center; gap: 5px;
}
.btn-reset { background: none; border: none; color: var(--danger); font-size: 0.68rem; font-weight: 700; cursor: pointer; opacity: 0.7; }
.btn-reset:hover { opacity: 1; }

/* ─── LIST ITEMS ─── */
.category-header {
  font-size: 0.62rem; font-weight: 800; letter-spacing: 2px;
  text-transform: uppercase; color: var(--accent);
  padding: 12px 4px 6px;
  display: flex; align-items: center; gap: 8px;
}
.category-header::after {
  content: ''; flex: 1; height: 1px; background: var(--border);
}
.list-item {
  display: grid;
  grid-template-columns: 1fr 72px 82px;
  align-items: center;
  background: var(--card); border: 1px solid var(--border);
  border-radius: 12px; padding: 12px 14px;
  margin-bottom: 7px;
  transition: all 0.25s;
  animation: itemIn 0.3s ease;
}
@keyframes itemIn { from { opacity:0; transform:translateX(-8px); } to { opacity:1; transform:none; } }
.list-item:hover { border-color: var(--border2); transform: translateY(-1px); }
.list-item.done { opacity: 0.45; }
.list-item.done .item-name { text-decoration: line-through; }
.item-name { font-weight: 700; font-size: 0.9rem; display: block; }
.item-cat { font-size: 0.62rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-top: 2px; }
.qty-big { font-size: 1.5rem; font-weight: 900; color: var(--accent); display: block; text-align: center; line-height: 1.1; }
.qty-unit { font-size: 0.62rem; color: var(--text-muted); text-align: center; display: block; }
.item-actions { display: flex; gap: 6px; justify-content: flex-end; align-items: center; }

/* ─── DRAG SORT ─── */
.sortable-category {
  cursor: grab; display: flex; align-items: center;
  gap: 8px; background: var(--card2); border: 1px solid var(--border);
  border-radius: var(--radius-sm); padding: 10px 12px;
  margin-bottom: 6px; transition: all 0.2s;
  user-select: none;
}
.sortable-category:hover { border-color: var(--border2); }
.sortable-category.drag-over { border-color: var(--primary); background: var(--primary-dim); }
.drag-handle { color: var(--text-muted); font-size: 0.9rem; }

/* ─── RECIPE EDITOR ROWS ─── */
.recipe-card {
  background: var(--surface);
  border: 1px solid var(--border2);
  border-radius: 12px;
  padding: 12px;
  margin-bottom: 8px;
  animation: itemIn 0.2s ease;
  position: relative;
}
.recipe-card-header {
  display: flex; align-items: center; gap: 8px; margin-bottom: 10px;
}
.recipe-card-header .ac-wrapper { flex: 1; }
.recipe-card-header input { margin: 0; font-weight: 700; }
.recipe-card-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr 1fr;
  gap: 6px;
}
.recipe-card-grid .field-sub { }
.recipe-card-grid .field-sub label { font-size: 0.6rem; color: var(--text-muted); font-weight: 700; letter-spacing: 0.5px; display: block; margin-bottom: 3px; }
.recipe-card-grid input, .recipe-card-grid select { padding: 8px; font-size: 0.82rem; margin: 0; }
.ing-cost-line {
  margin-top: 8px; padding-top: 8px;
  border-top: 1px solid var(--border);
  display: flex; align-items: center; justify-content: space-between;
}
.ing-cost-preview { font-size: 0.72rem; color: var(--amber); font-weight: 700; }
.btn-del-row {
  width: 32px; height: 32px; flex-shrink: 0;
  background: var(--danger-dim); border: 1px solid rgba(239,68,68,0.2);
  color: var(--danger); border-radius: 8px;
  cursor: pointer; font-size: 1rem; display: flex; align-items: center; justify-content: center;
  transition: all 0.2s;
}
.btn-del-row:hover { background: var(--danger); color: #fff; }

.ac-wrapper { position: relative; }
.ac-box {
  position: absolute; top: calc(100% + 4px); left: 0; right: 0;
  background: var(--card2); border: 1px solid var(--border2);
  border-radius: var(--radius-sm); z-index: 500;
  display: none; overflow: hidden;
  box-shadow: var(--shadow);
}
.ac-item { padding: 9px 12px; font-size: 0.82rem; cursor: pointer; transition: background 0.15s; }
.ac-item:hover { background: var(--primary-dim); }
.ac-item span { color: var(--text-muted); font-size: 0.7rem; margin-left: 6px; }

/* ─── CATALOG CARDS ─── */
.catalog-card {
  background: var(--card); border: 1px solid var(--border);
  border-radius: var(--radius); padding: 14px 16px;
  margin-bottom: 10px;
  display: flex; align-items: center; justify-content: space-between;
  transition: all 0.2s;
  animation: itemIn 0.3s ease;
}
.catalog-card:hover { border-color: var(--border2); transform: translateX(2px); }
.catalog-name { font-weight: 700; font-size: 0.95rem; }
.catalog-meta { font-size: 0.7rem; color: var(--text-muted); margin-top: 3px; }
.catalog-cost { font-size: 0.8rem; color: var(--amber); font-weight: 700; margin-top: 3px; }
.catalog-actions { display: flex; gap: 6px; }

/* ─── SEARCH ─── */
.search-field {
  position: relative; margin-bottom: 12px;
}
.search-field i {
  position: absolute; left: 12px; top: 50%; transform: translateY(-50%);
  color: var(--text-muted); font-size: 0.85rem;
}
.search-field input { padding-left: 36px; }

/* ─── TOAST ─── */
#toast-container { position: fixed; bottom: 95px; left: 50%; transform: translateX(-50%); z-index: 9999; display: flex; flex-direction: column; align-items: center; gap: 6px; }
.toast {
  background: var(--card2); border: 1px solid var(--border2);
  border-radius: 99px; padding: 9px 18px;
  font-size: 0.8rem; font-weight: 600;
  display: flex; align-items: center; gap: 8px;
  box-shadow: var(--shadow); white-space: nowrap;
  animation: toastIn 0.3s ease; opacity: 1;
  transition: opacity 0.3s;
}
.toast.hide { opacity: 0; }
@keyframes toastIn { from { opacity:0; transform:translateY(10px) scale(0.95); } to { opacity:1; transform:none; } }
.toast.success { border-color: rgba(34,197,94,0.3); color: var(--success); }
.toast.error { border-color: rgba(239,68,68,0.3); color: var(--danger); }
.toast.info { border-color: rgba(59,130,246,0.3); color: var(--primary); }

/* ─── BOTTOM NAV ─── */
.bottom-nav {
  position: fixed; bottom: 0; left: 0; right: 0;
  height: 78px;
  background: rgba(8,12,20,0.97);
  backdrop-filter: blur(20px);
  border-top: 1px solid var(--border);
  display: flex;
}
.nav-item {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  color: var(--text-muted); cursor: pointer;
  font-size: 0.65rem; font-weight: 700;
  letter-spacing: 0.5px; gap: 5px;
  transition: color 0.2s;
  position: relative;
}
.nav-item i { font-size: 1.3rem; }
.nav-item.active { color: var(--accent); }
.nav-item.active::before {
  content: ''; position: absolute; top: 0; left: 25%; right: 25%; height: 2px;
  background: var(--accent); border-radius: 0 0 4px 4px;
}
.nav-badge {
  position: absolute; top: 8px; right: calc(25% - 6px);
  background: var(--primary); color: #fff;
  font-size: 0.55rem; font-weight: 900;
  border-radius: 99px; padding: 1px 5px;
  min-width: 16px; text-align: center;
}

/* ─── EMPTY STATE ─── */
.empty { text-align: center; padding: 40px 20px; color: var(--text-muted); }
.empty i { font-size: 2.5rem; opacity: 0.3; margin-bottom: 12px; display: block; }
.empty p { font-size: 0.85rem; }

@media (max-width: 360px) {
  .recipe-card-grid { grid-template-columns: 1fr 1fr; }
  .header-actions .btn-ghost span { display: none; }
}
@media (min-width: 600px) {
  .recipe-card-grid { grid-template-columns: repeat(4, 1fr); }
  body { max-width: 640px; margin: 0 auto; }
}
.cost-pill {
  display: inline-flex; align-items: center; gap: 5px;
  background: var(--amber-dim); border: 1px solid rgba(245,158,11,0.2);
  border-radius: 99px; padding: 3px 10px;
  font-size: 0.72rem; font-weight: 700; color: var(--amber);
}

/* ─── IMPORT ZONE ─── */
.import-zone {
  border: 2px dashed var(--border2);
  border-radius: var(--radius);
  padding: 22px 16px;
  text-align: center;
  margin-bottom: 14px;
  transition: all 0.25s;
  display: flex; flex-direction: column; align-items: center; gap: 6px;
  background: var(--surface);
}
.import-zone:hover, .import-zone.drag-active {
  border-color: var(--primary);
  background: var(--primary-dim);
}
.import-zone.drag-active { transform: scale(1.01); }
.import-zone > i { font-size: 1.6rem; color: var(--text-muted); transition: color 0.2s; }
.import-zone.drag-active > i { color: var(--primary); }
.import-zone > span { font-size: 0.85rem; color: var(--text-soft); font-weight: 600; }
.import-hint { font-size: 0.68rem !important; color: var(--text-muted) !important; font-weight: 400 !important; }
.btn-import-pick {
  margin-top: 6px;
  display: inline-flex; align-items: center; gap: 6px;
  background: var(--card2); border: 1px solid var(--border2);
  color: var(--text-soft); padding: 7px 14px;
  border-radius: var(--radius-sm); font-size: 0.75rem; font-weight: 700;
  cursor: pointer; transition: all 0.2s;
  font-family: var(--font-body);
}
.btn-import-pick:hover { border-color: var(--primary); color: var(--text); }

/* ─── IMPORT MODAL ─── */
.modal-overlay {
  position: fixed; inset: 0; z-index: 2000;
  background: rgba(0,0,0,0.72);
  backdrop-filter: blur(6px);
  display: flex; align-items: flex-end;
  animation: fadeOverlay 0.2s ease;
}
@keyframes fadeOverlay { from { opacity:0 } to { opacity:1 } }
.modal-sheet {
  background: var(--card2);
  border: 1px solid var(--border2);
  border-radius: 24px 24px 0 0;
  padding: 12px 16px 36px;
  width: 100%; max-height: 82vh; overflow-y: auto;
  animation: slideUp 0.3s cubic-bezier(.16,1,.3,1);
}
@keyframes slideUp { from { transform: translateY(100%) } to { transform: none } }
.modal-handle { width: 40px; height: 4px; background: var(--border2); border-radius: 2px; margin: 0 auto 18px; }
.modal-title { font-family: var(--font-display); font-size: 1.05rem; font-weight: 800; margin-bottom: 4px; }
.modal-sub { font-size: 0.75rem; color: var(--text-muted); margin-bottom: 16px; line-height: 1.5; }
.import-recipe-item {
  display: flex; align-items: center; gap: 12px;
  background: var(--card); border: 1px solid var(--border);
  border-radius: 10px; padding: 12px 14px; margin-bottom: 8px;
  transition: border-color 0.15s;
}
.import-recipe-item:has(.import-check:checked) { border-color: var(--primary); background: var(--primary-dim); }
.import-recipe-item .info { flex: 1; }
.import-recipe-item .name { font-weight: 700; font-size: 0.9rem; }
.import-recipe-item .meta { font-size: 0.7rem; color: var(--text-muted); margin-top: 2px; }
.badge-exists { display: inline-flex; align-items: center; gap: 3px; font-size: 0.62rem; color: var(--amber); font-weight: 700; background: var(--amber-dim); border: 1px solid rgba(245,158,11,0.2); border-radius: 4px; padding: 1px 6px; margin-top: 3px; }
.badge-new { display: inline-flex; align-items: center; gap: 3px; font-size: 0.62rem; color: var(--success); font-weight: 700; background: var(--success-dim); border: 1px solid rgba(34,197,94,0.2); border-radius: 4px; padding: 1px 6px; margin-top: 3px; }
.import-check { width: 20px; height: 20px; accent-color: var(--primary); cursor: pointer; flex-shrink: 0; }
.modal-actions { display: flex; gap: 10px; margin-top: 16px; }
.modal-actions .btn { flex: 1; }
.import-error { background: var(--danger-dim); border: 1px solid rgba(239,68,68,0.2); border-radius: 10px; padding: 14px; font-size: 0.82rem; color: var(--danger); }
</style>
</head>
<body>

<div id="toast-container"></div>

<header>
  <div class="header-inner">
    <div class="logo">OVNI <span>CTRL</span> <sub>V9</sub></div>
    <div class="header-actions">
      <button class="btn-ghost accent-ghost" onclick="exportPDF()"><i class="fa-solid fa-file-pdf"></i> PDF</button>
      <button class="btn-ghost" onclick="exportJSON()"><i class="fa-solid fa-download"></i> JSON</button>
    </div>
  </div>
  <div id="shopping-tabs" class="tab-strip" style="display:none;">
    <div class="tab active" id="tab-todo" onclick="setMode('todo')">À ACHETER <span class="badge" id="cnt-todo">0</span></div>
    <div class="tab" id="tab-done" onclick="setMode('done')">PANIER <span class="badge" id="cnt-done">0</span></div>
    <div class="tab" id="tab-sort" onclick="setMode('sort')"><i class="fa-solid fa-arrows-up-down"></i> RAYONS</div>
  </div>
</header>

<!-- ── PROD VIEW ── -->
<div id="sec-prod" class="section active">
  <div class="card">
    <div class="card-title"><i class="fa-solid fa-bolt"></i>Lancer une Production</div>
    <div class="row" style="margin-bottom:10px;">
      <div class="field-group" style="flex:2; margin:0">
        <div class="field-label">Fiche technique</div>
        <select id="prod-select"></select>
      </div>
      <div class="field-group" style="flex:1; margin:0">
        <div class="field-label">Quantité</div>
        <input type="number" id="prod-qty" value="1" min="1">
      </div>
    </div>
    <div id="prod-cost-preview" style="margin-bottom:10px; display:none;">
      <span class="cost-pill"><i class="fa-solid fa-euro-sign"></i> Coût estimé : <strong id="prod-cost-val">0.00 €</strong></span>
    </div>
    <button class="btn btn-primary" onclick="addProduction()"><i class="fa-solid fa-plus"></i> AJOUTER À LA SESSION</button>
  </div>

  <div class="card">
    <div class="card-title"><i class="fa-solid fa-pen"></i>Article Hors-Fiche</div>
    <div class="field-group">
      <div class="field-label">Nom de l'article</div>
      <input type="text" id="s-name" placeholder="ex: Sel fin" oninput="validateSingle()">
