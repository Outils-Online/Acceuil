      <div class="session-cost" id="session-cost-badge" style="display:none;">
        <i class="fa-solid fa-coins"></i> <span id="session-cost-total"></span>
      </div>
      <button class="btn-reset" onclick="resetSession()">⟳ RÉINITIALISER</button>
    </div>
  </div>
  <div id="list-display"></div>
</div>

<!-- ── LABO VIEW ── -->
<div id="sec-labo" class="section">
  <div class="card">
    <div class="card-title" id="labo-title"><i class="fa-solid fa-flask"></i>Créer une Fiche</div>
    <div class="field-group">
      <div class="field-label">Nom de la recette</div>
      <input type="text" id="recipe-name" placeholder="ex: Burger Signature">
    </div>
    <div id="recipe-rows"></div>
    <div id="recipe-total-cost" class="cost-pill" style="display:none; margin-bottom:12px;"><i class="fa-solid fa-coins"></i> </div>
    <button class="btn btn-neutral" onclick="addRow()" style="margin-bottom:12px;">
      <i class="fa-solid fa-plus"></i> Ajouter un ingrédient
    </button>
    <div class="row">
      <button class="btn btn-success" onclick="saveRecipe()"><i class="fa-solid fa-floppy-disk"></i> ENREGISTRER</button>
      <button class="btn btn-danger" id="btn-cancel" style="display:none;" onclick="cancelEdit()">ANNULER</button>
    </div>
  </div>

  <!-- IMPORT -->
  <div class="import-zone" id="import-zone"
    ondragover="event.preventDefault(); this.classList.add('drag-active')"
    ondragleave="this.classList.remove('drag-active')"
    ondrop="handleImportDrop(event)">
    <i class="fa-solid fa-file-import"></i>
    <span>Glisse un fichier <strong>JSON</strong> ici</span>
    <span class="import-hint">Fiche unique · Tableau · Backup complet</span>
    <label class="btn-import-pick">
      <i class="fa-solid fa-folder-open"></i> Parcourir
      <input type="file" accept=".json" style="display:none" onchange="handleImportFile(this)">
    </label>
  </div>

  <div class="search-field">
    <i class="fa-solid fa-magnifying-glass"></i>
    <input type="text" id="labo-search" placeholder="Rechercher une fiche…" oninput="renderLabo()">
  </div>

  <div id="catalog-display"></div>
