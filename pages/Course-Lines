      <div>
        <div class="field-label">Unité</div>
        <select id="s-unit">
          <option>kg</option><option>g</option><option>L</option><option>cl</option><option>pièce</option><option>boîte</option>
        </select>
      </div>
      <div>
        <div class="field-label">Rayon</div>
        <select id="s-cat">
          <option>Fruits &amp; Légumes</option><option>Viandes</option><option>Poissons</option>
          <option>Épicerie salée</option><option>Épicerie sucrée</option><option>Liquides</option>
          <option>Produits frais</option><option>Surgelés</option><option>Autre</option>
