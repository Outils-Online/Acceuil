<nav class="bottom-nav">
  <div class="nav-item active" id="nav-prod" onclick="switchView('prod')">
    <i class="fa-solid fa-rocket"></i>PROD
  </div>
  <div class="nav-item" id="nav-list" onclick="switchView('list')">
    <i class="fa-solid fa-cart-shopping"></i>COURSES
    <span id="nav-badge" class="nav-badge" style="display:none;"></span>
  </div>
  <div class="nav-item" id="nav-labo" onclick="switchView('labo')">
    <i class="fa-solid fa-book-open"></i>LABO
  </div>
</nav>

<script>
// ═══════════════════════════════════════════
//  STATE
// ═══════════════════════════════════════════
const DEFAULT_CATEGORIES = [
  'Fruits & Légumes','Viandes','Poissons','Produits frais',
  'Épicerie salée','Épicerie sucrée','Liquides','Surgelés','Autre'
];

let state = {
  view: 'prod',
  listMode: 'todo',
  editingId: null,
  session: { recipes: {}, singles: 0, totalCost: 0 },
  list: [],
  recipes: [
    {
      id: 1, name: 'OVNI Burger',
      ingredients: [
        { name: 'Pain brioche', qty: 1, unit: 'pièce', cat: 'Épicerie salée', price: 0.35 },
        { name: 'Steak haché', qty: 180, unit: 'g', cat: 'Viandes', price: 1.20 },
        { name: 'Cheddar', qty: 30, unit: 'g', cat: 'Produits frais', price: 0.40 },
        { name: 'Laitue', qty: 20, unit: 'g', cat: 'Fruits & Légumes', price: 0.08 },
        { name: 'Tomate', qty: 50, unit: 'g', cat: 'Fruits & Légumes', price: 0.15 },
      ]
    }
  ],
  categoryOrder: [...DEFAULT_CATEGORIES]
};

// ─── PERSISTENCE ───
function loadState() {
  try {
    const saved = localStorage.getItem('ovni_v9');
    if (saved) {
      const parsed = JSON.parse(saved);
      state = { ...state, ...parsed };
      if (!state.categoryOrder || !state.categoryOrder.length) state.categoryOrder = [...DEFAULT_CATEGORIES];
    }
  } catch(e) { console.warn('Load error', e); }
}

function saveState() {
  try { localStorage.setItem('ovni_v9', JSON.stringify(state)); } catch(e) {}
  render();
}

// ═══════════════════════════════════════════
//  TOAST
// ═══════════════════════════════════════════
function toast(msg, type = 'success') {
  const el = document.createElement('div');
  el.className = `toast ${type}`;
  const icons = { success: 'fa-check-circle', error: 'fa-triangle-exclamation', info: 'fa-info-circle' };
  el.innerHTML = `<i class="fa-solid ${icons[type] || icons.success}"></i>${msg}`;
  document.getElementById('toast-container').appendChild(el);
  setTimeout(() => { el.classList.add('hide'); setTimeout(() => el.remove(), 400); }, 2200);
}

// ═══════════════════════════════════════════
//  NAVIGATION
// ═══════════════════════════════════════════
function switchView(v) {
  state.view = v;
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('sec-' + v).classList.add('active');
  document.getElementById('nav-' + v).classList.add('active');
  document.getElementById('shopping-tabs').style.display = v === 'list' ? 'flex' : 'none';
  render();
}

function setMode(m) {
  state.listMode = m;
  ['todo','done','sort'].forEach(id => {
    const el = document.getElementById('tab-' + id);
    if (el) el.classList.toggle('active', id === m);
  });
  render();
}

// ═══════════════════════════════════════════
//  PRODUCTION
// ═══════════════════════════════════════════
function addProduction() {
  const name = document.getElementById('prod-select').value;
  const qty = parseInt(document.getElementById('prod-qty').value);
  if (!name) return toast('Sélectionne une fiche', 'error');
  if (!qty || qty <= 0) return toast('Quantité invalide', 'error');

  const recipe = state.recipes.find(r => r.name === name);
  if (!recipe) return;

  state.session.recipes[name] = (state.session.recipes[name] || 0) + qty;

  // Calculate cost: recipeUnitCost = cost for 1 unit, multiply by production qty
  const batchCost = recipeUnitCost(recipe) * qty;

  recipe.ingredients.forEach(ing => {
    const exist = state.list.find(i => i.name === ing.name && i.unit === ing.unit);
    if (exist) { exist.qty = parseFloat((exist.qty + ing.qty * qty).toFixed(4)); exist.done = false; }
    else state.list.push({ ...ing, qty: parseFloat((ing.qty * qty).toFixed(4)), done: false });
  });
  state.session.totalCost = (state.session.totalCost || 0) + batchCost;

  saveState();
  toast(`${qty}× ${name} ajouté${qty > 1 ? 's' : ''} ✓`);
}

function addSingle() {
  const name = document.getElementById('s-name').value.trim();
  const qty = parseFloat(document.getElementById('s-qty').value);
  const unit = document.getElementById('s-unit').value;
  const cat = document.getElementById('s-cat').value;

  if (!name) return toast('Nom requis', 'error');
  if (isNaN(qty) || qty <= 0) return toast('Quantité invalide', 'error');

  state.session.singles++;
  const exist = state.list.find(i => i.name.toLowerCase() === name.toLowerCase() && i.unit === unit);
  if (exist) { exist.qty = parseFloat((exist.qty + qty).toFixed(4)); exist.done = false; }
  else state.list.push({ name, qty, unit, cat, done: false });

  document.getElementById('s-name').value = '';
  document.getElementById('s-qty').value = '';
  saveState();
  toast(`${name} ajouté`);
}

function validateSingle() {}

function resetSession() {
  if (!confirm('Vider toute la liste de courses ?')) return;
  state.list = [];
  state.session = { recipes: {}, singles: 0, totalCost: 0 };
  saveState();
  toast('Session réinitialisée', 'info');
}

function toggleItem(name, unit) {
  const item = state.list.find(i => i.name === name && i.unit === unit);
  if (item) { item.done = !item.done; saveState(); }
}

function delItem(name, unit) {
  state.list = state.list.filter(i => !(i.name === name && i.unit === unit));
  saveState();
  toast('Article supprimé', 'info');
}

// ═══════════════════════════════════════════
//  RECIPE EDITOR
// ═══════════════════════════════════════════
function addRow(data = {}) {
  const cats = [
    'Fruits & Légumes','Viandes','Poissons','Produits frais',
    'Épicerie salée','Épicerie sucrée','Liquides','Surgelés','Autre'
  ];
  const units = ['kg','g','L','cl','ml','pièce','boîte','sachet','botte','tranche','portion','dose'];
  const catOpts = cats.map(c => `<option value="${c}" ${data.cat === c ? 'selected' : ''}>${c}</option>`).join('');
  const unitOpts = units.map(u => `<option value="${u}" ${data.unit === u ? 'selected' : ''}>${u}</option>`).join('');

  const div = document.createElement('div');
  div.className = 'recipe-card';
  div.innerHTML = `
    <div class="recipe-card-header">
      <div class="ac-wrapper" style="flex:1">
        <input type="text" class="in-n" placeholder="Nom de l'ingrédient" value="${escHtml(data.name||'')}" oninput="handleAC(this); updateRowCost(this)">
        <div class="ac-box"></div>
      </div>
      <button class="btn-del-row" onclick="this.closest('.recipe-card').remove(); updateRecipeTotalCost()">×</button>
    </div>
    <div class="recipe-card-grid">
      <div class="field-sub">
        <label>Quantité</label>
        <input type="number" class="in-q" placeholder="0" step="0.001" min="0" value="${data.qty||''}" oninput="updateRowCost(this)">
      </div>
      <div class="field-sub">
        <label>Unité</label>
        <select class="in-u">${unitOpts}</select>
      </div>
      <div class="field-sub">
        <label>Rayon</label>
        <select class="in-c">${catOpts}</select>
      </div>
      <div class="field-sub">
        <label>Prix (€) pour cette qté</label>
        <input type="number" class="in-p" placeholder="0.00" step="0.001" min="0" value="${data.price != null && data.price > 0 ? data.price : ''}" oninput="updateRowCost(this)">
      </div>
    </div>
    <div class="ing-cost-line">
      <span style="font-size:0.65rem;color:var(--text-muted);">Coût de cet ingrédient</span>
      <span class="ing-cost-preview">—</span>
    </div>`;
  document.getElementById('recipe-rows').appendChild(div);
  // init cost display
  updateRowCost(div.querySelector('.in-q'));
}

function handleAC(input) {
  const val = input.value.toLowerCase().trim();
  const box = input.nextElementSibling;
  if (val.length < 1) { box.style.display = 'none'; return; }
  const known = [];
  state.recipes.forEach(r => r.ingredients.forEach(i => {
    if (!known.find(k => k.name.toLowerCase() === i.name.toLowerCase())) known.push(i);
  }));
  const matches = known.filter(i => i.name.toLowerCase().includes(val)).slice(0, 5);
  if (matches.length) {
    box.innerHTML = matches.map(m =>
      `<div class="ac-item" onclick="selectAC(this,'${escAttr(m.name)}','${escAttr(m.unit)}','${escAttr(m.cat)}')">${escHtml(m.name)}<span>${m.unit} · ${m.cat}</span></div>`
    ).join('');
    box.style.display = 'block';
  } else { box.style.display = 'none'; }
}

function updateRowCost(input) {
  const card = input.closest('.recipe-card');
  if (!card) return;
  const price = parseFloat(card.querySelector('.in-p').value) || 0;
  const preview = card.querySelector('.ing-cost-preview');
  if (price > 0) {
    preview.textContent = `${price.toFixed(2)} €`;
    preview.style.color = 'var(--amber)';
  } else {
    preview.textContent = '—';
    preview.style.color = 'var(--text-muted)';
  }
  updateRecipeTotalCost();
}

function updateRecipeTotalCost() {
  let total = 0;
  document.querySelectorAll('.recipe-card').forEach(card => {
    const qty = parseFloat(card.querySelector('.in-q').value) || 0;
    const price = parseFloat(card.querySelector('.in-p').value) || 0;
    total += qty * price;
  });
  const el = document.getElementById('recipe-total-cost');
  if (el) {
    if (total > 0) {
      el.innerHTML = `<i class="fa-solid fa-coins"></i> Coût total fiche : ${total.toFixed(2)} €`;
      el.style.display = 'inline-flex';
    } else {
      el.style.display = 'none';
    }
  }
}


function selectAC(el, n, u, c) {
  const card = el.closest('.recipe-card');
  card.querySelector('.in-n').value = n;
  const unitSel = card.querySelector('.in-u');
  const opt = [...unitSel.options].find(o => o.value === u);
  if (opt) unitSel.value = u;
  card.querySelector('.in-c').value = c;
  el.closest('.ac-box').style.display = 'none';
  updateRowCost(card.querySelector('.in-q'));
}

document.addEventListener('click', e => {
  if (!e.target.closest('.ac-wrapper')) {
    document.querySelectorAll('.ac-box').forEach(b => b.style.display = 'none');
  }
});

function saveRecipe() {
  const name = document.getElementById('recipe-name').value.trim();
  if (!name) return toast('Nom de fiche requis', 'error');

  // Duplicate name check
  const dupCheck = state.recipes.find(r => r.name.toLowerCase() === name.toLowerCase() && r.id !== state.editingId);
  if (dupCheck) return toast('Ce nom existe déjà', 'error');

  const ings = [];
  let valid = true;
  document.querySelectorAll('.recipe-card').forEach(row => {
    const n = row.querySelector('.in-n').value.trim();
    const q = parseFloat(row.querySelector('.in-q').value);
    const p = parseFloat(row.querySelector('.in-p').value) || 0;
    if (!n || isNaN(q) || q <= 0) { valid = false; return; }
    ings.push({ name: n, qty: q, unit: row.querySelector('.in-u').value, cat: row.querySelector('.in-c').value, price: p });
  });

  if (!valid) return toast('Vérifie les ingrédients (nom & quantité)', 'error');
  if (!ings.length) return toast('Ajoute au moins un ingrédient', 'error');

  if (state.editingId) {
    const idx = state.recipes.findIndex(r => r.id === state.editingId);
    state.recipes[idx] = { id: state.editingId, name, ingredients: ings };
    toast(`${name} mis à jour`);
  } else {
    state.recipes.push({ id: Date.now(), name, ingredients: ings });
    toast(`${name} créé ✓`);
  }
  cancelEdit();
  saveState();
}

function editRecipe(id) {
  const r = state.recipes.find(x => x.id === id);
  if (!r) return;
  state.editingId = id;
  document.getElementById('recipe-name').value = r.name;
  document.getElementById('recipe-rows').innerHTML = '';
  r.ingredients.forEach(i => addRow(i));
  document.getElementById('labo-title').innerHTML = `<i class="fa-solid fa-pen"></i>Modifier : ${escHtml(r.name)}`;
  document.getElementById('btn-cancel').style.display = '';
  document.getElementById('sec-labo').scrollIntoView({ behavior: 'smooth' });
}

function deleteRecipe(id) {
  if (!confirm('Supprimer cette fiche ?')) return;
  state.recipes = state.recipes.filter(r => r.id !== id);
  toast('Fiche supprimée', 'info');
  saveState();
}

function cancelEdit() {
  state.editingId = null;
  document.getElementById('recipe-name').value = '';
  document.getElementById('recipe-rows').innerHTML = '';
  const costEl = document.getElementById('recipe-total-cost');
  if (costEl) costEl.style.display = 'none';
  document.getElementById('labo-title').innerHTML = `<i class="fa-solid fa-flask"></i>Créer une Fiche`;
  document.getElementById('btn-cancel').style.display = 'none';
  addRow();
}

// ═══════════════════════════════════════════
//  DRAG-SORT CATEGORIES
// ═══════════════════════════════════════════
let dragSrc = null;

function buildSortView() {
  const container = document.getElementById('list-display');
  container.innerHTML = '';

  const header = document.createElement('div');
  header.innerHTML = `<div style="font-size:0.72rem;color:var(--text-muted);margin-bottom:10px;padding:0 2px;">
    <i class="fa-solid fa-info-circle" style="color:var(--primary)"></i>
    Glisse pour réorganiser les rayons
  </div>`;
  container.appendChild(header);

  // Merge: existing categories from list + default order
  const listCats = [...new Set(state.list.map(i => i.cat))];
  const allCats = [...new Set([...state.categoryOrder, ...listCats, ...DEFAULT_CATEGORIES])];

  allCats.forEach(cat => {
    const div = document.createElement('div');
    div.className = 'sortable-category';
    div.draggable = true;
    div.dataset.cat = cat;
    const count = state.list.filter(i => i.cat === cat).length;
    div.innerHTML = `<span class="drag-handle"><i class="fa-solid fa-grip-lines"></i></span>
      <span style="flex:1; font-weight:700; font-size:0.88rem;">${escHtml(cat)}</span>
      ${count ? `<span style="font-size:0.7rem;color:var(--text-muted);">${count} article${count>1?'s':''}</span>` : ''}`;

    div.addEventListener('dragstart', () => { dragSrc = div; div.style.opacity = '0.4'; });
    div.addEventListener('dragend', () => { div.style.opacity = '1'; dragSrc = null; });
    div.addEventListener('dragover', e => { e.preventDefault(); div.classList.add('drag-over'); });
    div.addEventListener('dragleave', () => div.classList.remove('drag-over'));
    div.addEventListener('drop', e => {
      e.preventDefault(); div.classList.remove('drag-over');
      if (dragSrc && dragSrc !== div) {
        const rows = [...container.querySelectorAll('.sortable-category')];
        const srcIdx = rows.indexOf(dragSrc);
        const dstIdx = rows.indexOf(div);
        const newOrder = allCats.filter(c => c !== dragSrc.dataset.cat);
        newOrder.splice(dstIdx, 0, dragSrc.dataset.cat);
        state.categoryOrder = newOrder;
        saveState();
      }
    });
    container.appendChild(div);
  });
}

// ═══════════════════════════════════════════
//  EXPORT
// ═══════════════════════════════════════════
function exportJSON() {
  const blob = new Blob([JSON.stringify(state, null, 2)], { type: 'application/json' });
  const a = document.createElement('a'); a.href = URL.createObjectURL(blob);
  a.download = `ovni_backup_${dateStr()}.json`; a.click();
  toast('JSON exporté', 'info');
}

function exportPDF() {
  if (!state.list.length) return toast('La liste est vide', 'error');

  const { jsPDF } = window.jspdf;
  const doc = new jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4' });

  // Header
  doc.setFillColor(8, 12, 20);
  doc.rect(0, 0, 210, 297, 'F');
  doc.setTextColor(248, 250, 252);
  doc.setFontSize(22);
  doc.setFont('helvetica', 'bold');
  doc.text('OVNI CONTROL', 14, 22);
  doc.setFontSize(10);
  doc.setTextColor(100, 116, 139);
  doc.text('Liste de courses — ' + new Date().toLocaleDateString('fr-FR'), 14, 30);

  // Session info
  const sessionParts = [];
  for (const [n, q] of Object.entries(state.session.recipes)) sessionParts.push(`${q}× ${n}`);
  if (sessionParts.length) {
    doc.setFontSize(8); doc.setTextColor(200, 255, 87);
    doc.text('Session : ' + sessionParts.join(' · '), 14, 37);
  }

  // Cost
  if (state.session.totalCost > 0) {
    doc.setFontSize(8); doc.setTextColor(245, 158, 11);
    doc.text(`Coût estimé : ${state.session.totalCost.toFixed(2)} €`, 14, 43);
  }

  // Group by category
  const grouped = {};
  state.list.forEach(item => {
    if (!grouped[item.cat]) grouped[item.cat] = [];
    grouped[item.cat].push(item);
  });

  const ordered = state.categoryOrder.filter(c => grouped[c]).concat(
    Object.keys(grouped).filter(c => !state.categoryOrder.includes(c))
  );

  let yOffset = 50;
  ordered.forEach(cat => {
    if (!grouped[cat]) return;
    const rows = grouped[cat].map(i => [
      i.done ? '✓' : '□',
      i.name,
      `${formatQty(i.qty)} ${i.unit}`,
      i.cat
    ]);
    doc.autoTable({
      startY: yOffset,
      head: [[{ content: cat, colSpan: 4, styles: { fillColor: [30, 41, 59], textColor: [200, 255, 87], fontStyle: 'bold', fontSize: 9 } }]],
      body: rows,
      columns: [
        { header: '', dataKey: 0 },
        { header: 'Article', dataKey: 1 },
        { header: 'Quantité', dataKey: 2 },
        { header: 'Rayon', dataKey: 3 }
      ],
      theme: 'plain',
      styles: { fillColor: [13, 20, 32], textColor: [241, 245, 249], fontSize: 9, cellPadding: 3 },
      alternateRowStyles: { fillColor: [17, 24, 39] },
      margin: { left: 14, right: 14 },
      didParseCell: (data) => {
        if (data.row.raw && data.row.raw[0] === '✓') {
          data.cell.styles.textColor = [100, 116, 139];
        }
      }
    });
    yOffset = doc.lastAutoTable.finalY + 6;
  });

  doc.save(`ovni_courses_${dateStr()}.pdf`);
  toast('PDF généré ✓');
}

function dateStr() {
  const d = new Date();
  return `${d.getFullYear()}${String(d.getMonth()+1).padStart(2,'0')}${String(d.getDate()).padStart(2,'0')}`;
}

// ═══════════════════════════════════════════
//  UTILS
// ═══════════════════════════════════════════
function escHtml(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function escAttr(s) { return String(s).replace(/'/g, "\\'"); }
function formatQty(n) {
  const s = parseFloat(n).toString();
  return s.replace('.', ',');
}
function recipeUnitCost(recipe) {
  // price field = cost for that ingredient's qty in one production unit
  // e.g. 180g steak at price=1.20 means 1.20€ for 180g (not per gram)
  return recipe.ingredients.reduce((sum, i) => sum + (i.price || 0), 0);
}

// ═══════════════════════════════════════════
//  RENDER
// ═══════════════════════════════════════════
function render() {
  renderProdView();
  renderListView();
  renderLabo();
  renderNav();
}

function renderProdView() {
  const sel = document.getElementById('prod-select');
  if (!sel) return;
  const cur = sel.value;
  sel.innerHTML = state.recipes.length
    ? state.recipes.map(r => `<option ${r.name===cur?'selected':''}>${escHtml(r.name)}</option>`).join('')
    : '<option disabled>Aucune fiche</option>';
  updateCostPreview();
}

function updateCostPreview() {
  const name = document.getElementById('prod-select')?.value;
  const qty = parseInt(document.getElementById('prod-qty')?.value) || 0;
  const recipe = state.recipes.find(r => r.name === name);
  const preview = document.getElementById('prod-cost-preview');
  const val = document.getElementById('prod-cost-val');
  if (recipe && qty > 0) {
    const cost = recipeUnitCost(recipe) * qty;
    if (cost > 0) {
      val.textContent = `${cost.toFixed(2)} €`;
      preview.style.display = '';
      return;
    }
  }
  preview.style.display = 'none';
}

document.addEventListener('change', e => {
  if (e.target.id === 'prod-select' || e.target.id === 'prod-qty') updateCostPreview();
});
document.addEventListener('input', e => {
  if (e.target.id === 'prod-qty') updateCostPreview();
});

function renderListView() {
  if (state.view !== 'list') return;
  if (state.listMode === 'sort') { buildSortView(); return; }

  // Session banner
  const parts = [];
  for (const [n, q] of Object.entries(state.session.recipes))
    parts.push(`<span class="tag"><span class="session-tag-qty">${q}×</span> ${escHtml(n)}</span>`);
  if (state.session.singles > 0)
    parts.push(`<span class="tag"><span class="session-tag-qty">${state.session.singles}</span> manuelle${state.session.singles>1?'s':''}</span>`);

  document.getElementById('session-text').innerHTML = parts.length ? parts.join('') : '<span style="color:var(--text-muted);font-size:0.85rem;">Aucune production lancée</span>';

  const costBadge = document.getElementById('session-cost-badge');
  if (state.session.totalCost > 0) {
    document.getElementById('session-cost-total').textContent = state.session.totalCost.toFixed(2) + ' €';
    costBadge.style.display = 'flex';
  } else { costBadge.style.display = 'none'; }

  // Counts
  document.getElementById('cnt-todo').textContent = state.list.filter(i => !i.done).length;
  document.getElementById('cnt-done').textContent = state.list.filter(i => i.done).length;

  const display = document.getElementById('list-display');
  display.innerHTML = '';

  const items = state.list.filter(i => i.done === (state.listMode === 'done'));

  if (!items.length) {
    display.innerHTML = `<div class="empty"><i class="fa-solid fa-${state.listMode==='done'?'check-double':'list-check'}"></i><p>${state.listMode==='done'?'Aucun article coché':'La liste est vide'}</p></div>`;
    return;
  }

  // Group by ordered categories
  const grouped = {};
  items.forEach(i => { grouped[i.cat] = grouped[i.cat] || []; grouped[i.cat].push(i); });

  const ordered = state.categoryOrder.filter(c => grouped[c]).concat(
    Object.keys(grouped).filter(c => !state.categoryOrder.includes(c))
  );

  ordered.forEach(cat => {
    if (!grouped[cat]) return;
    display.innerHTML += `<div class="category-header">${escHtml(cat)}</div>`;
    grouped[cat].forEach(item => {
      const key = `${escAttr(item.name)}|${escAttr(item.unit)}`;
      display.innerHTML += `
        <div class="list-item ${item.done ? 'done' : ''}">
          <div>
            <span class="item-name">${escHtml(item.name)}</span>
            <span class="item-cat">${escHtml(item.cat)}</span>
          </div>
          <div>
            <span class="qty-big">${formatQty(item.qty)}</span>
            <span class="qty-unit">${escHtml(item.unit)}</span>
          </div>
          <div class="item-actions">
            <button class="btn-icon btn-icon-check" onclick="toggleItem('${escAttr(item.name)}','${escAttr(item.unit)}')">
              <i class="fa-solid fa-${item.done ? 'rotate-left' : 'check'}"></i>
            </button>
            <button class="btn-icon btn-icon-trash" onclick="delItem('${escAttr(item.name)}','${escAttr(item.unit)}')">
              <i class="fa-solid fa-trash"></i>
            </button>
          </div>
        </div>`;
    });
  });
}

function renderLabo() {
  const q = (document.getElementById('labo-search')?.value || '').toLowerCase();
  const filtered = q
    ? state.recipes.filter(r => r.name.toLowerCase().includes(q))
    : state.recipes;

  const container = document.getElementById('catalog-display');
  if (!container) return;

  if (!filtered.length) {
    container.innerHTML = `<div class="empty"><i class="fa-solid fa-book-open"></i><p>${q ? 'Aucun résultat' : 'Aucune fiche créée'}</p></div>`;
    return;
  }

  container.innerHTML = filtered.map(r => {
    const cost = recipeUnitCost(r);
    return `
    <div class="catalog-card">
      <div>
        <div class="catalog-name">${escHtml(r.name)}</div>
        <div class="catalog-meta">${r.ingredients.length} ingrédient${r.ingredients.length>1?'s':''}</div>
        ${cost > 0 ? `<div class="catalog-cost"><i class="fa-solid fa-euro-sign" style="font-size:0.7rem"></i> ${cost.toFixed(2)} € / unité</div>` : ''}
      </div>
      <div class="catalog-actions">
        <button class="btn-icon btn-icon-edit" onclick="editRecipe(${r.id})"><i class="fa-solid fa-pen"></i></button>
        <button class="btn-icon btn-icon-trash" onclick="deleteRecipe(${r.id})"><i class="fa-solid fa-trash"></i></button>
      </div>
    </div>`;
  }).join('');
}

function renderNav() {
  const todoCount = state.list.filter(i => !i.done).length;
  const badge = document.getElementById('nav-badge');
  if (todoCount > 0) { badge.textContent = todoCount; badge.style.display = ''; }
  else { badge.style.display = 'none'; }
}

// ═══════════════════════════════════════════
//  IMPORT JSON
// ═══════════════════════════════════════════
function handleImportDrop(e) {
  e.preventDefault();
  document.getElementById('import-zone').classList.remove('drag-active');
  const file = e.dataTransfer.files[0];
  if (!file || !file.name.endsWith('.json')) return toast('Fichier JSON requis', 'error');
  readImportFile(file);
}

function handleImportFile(input) {
  const file = input.files[0];
  if (!file) return;
  readImportFile(file);
  input.value = ''; // reset so same file can be re-selected
}

function readImportFile(file) {
  const reader = new FileReader();
  reader.onload = e => {
    try {
      const data = JSON.parse(e.target.result);
      const recipes = parseImportedRecipes(data);
      if (!recipes.length) return toast('Aucune fiche valide trouvée', 'error');
      showImportModal(recipes);
    } catch(err) {
      toast('Fichier JSON invalide', 'error');
    }
  };
  reader.readAsText(file);
}

function parseImportedRecipes(data) {
  // Support 3 formats:
  // 1. Full backup: { recipes: [...] }
  // 2. Array of recipes: [{ name, ingredients }, ...]
  // 3. Single recipe: { name, ingredients: [...] }
  let candidates = [];

  if (data && Array.isArray(data.recipes)) {
    candidates = data.recipes;
  } else if (Array.isArray(data)) {
    candidates = data;
  } else if (data && typeof data === 'object' && data.name) {
    candidates = [data];
  }

  return candidates.filter(r =>
    r && typeof r.name === 'string' && r.name.trim() &&
    Array.isArray(r.ingredients) && r.ingredients.length > 0
  ).map(r => ({
    id: r.id || Date.now() + Math.random(),
    name: r.name.trim(),
    ingredients: r.ingredients.map(i => ({
      name: i.name || '',
      qty: parseFloat(i.qty) || 0,
      unit: i.unit || 'pièce',
      cat: i.cat || 'Autre',
      price: parseFloat(i.price) || 0
    })).filter(i => i.name && i.qty > 0)
  })).filter(r => r.ingredients.length > 0);
}

function showImportModal(recipes) {
  const existing = new Set(state.recipes.map(r => r.name.toLowerCase()));

  const itemsHtml = recipes.map((r, idx) => {
    const isExisting = existing.has(r.name.toLowerCase());
    const cost = r.ingredients.reduce((s, i) => s + (i.price || 0), 0);
    const costText = cost > 0 ? ` · ${cost.toFixed(2)} €` : '';
    const badge = isExisting
      ? `<span class="badge-exists"><i class="fa-solid fa-triangle-exclamation"></i> Existe déjà</span>`
      : `<span class="badge-new"><i class="fa-solid fa-plus"></i> Nouveau</span>`;
    return `
      <label class="import-recipe-item" style="cursor:pointer">
        <input type="checkbox" class="import-check" data-idx="${idx}" ${isExisting ? '' : 'checked'}>
        <div class="info">
          <div class="name">${escHtml(r.name)}</div>
          <div class="meta">${r.ingredients.length} ingrédient${r.ingredients.length>1?'s':''}${costText}</div>
          <div>${badge}</div>
        </div>
      </label>`;
  }).join('');

  const modal = document.createElement('div');
  modal.className = 'modal-overlay';
  modal.id = 'import-modal';
  modal.innerHTML = `
    <div class="modal-sheet">
      <div class="modal-handle"></div>
      <div class="modal-title"><i class="fa-solid fa-file-import" style="color:var(--primary);margin-right:8px;"></i>${recipes.length} fiche${recipes.length>1?'s':''} détectée${recipes.length>1?'s':''}</div>
      <div class="modal-sub">Sélectionne les fiches à importer. Les fiches existantes seront <strong style="color:var(--amber)">écrasées</strong> si cochées.</div>
      <div id="import-list">${itemsHtml}</div>
      <div class="modal-actions">
        <button class="btn btn-neutral" onclick="closeImportModal()">Annuler</button>
        <button class="btn btn-success" onclick="confirmImport(${JSON.stringify(recipes).replace(/</g,'\\u003c')})">
          <i class="fa-solid fa-check"></i> Importer la sélection
        </button>
      </div>
    </div>`;

  // Close on overlay click
  modal.addEventListener('click', e => { if (e.target === modal) closeImportModal(); });
  document.body.appendChild(modal);
}

function confirmImport(recipes) {
  const checked = [...document.querySelectorAll('.import-check:checked')].map(c => parseInt(c.dataset.idx));
  if (!checked.length) return toast('Aucune fiche sélectionnée', 'error');

  let added = 0, replaced = 0;
  checked.forEach(idx => {
    const r = recipes[idx];
    const existIdx = state.recipes.findIndex(x => x.name.toLowerCase() === r.name.toLowerCase());
    if (existIdx >= 0) {
      state.recipes[existIdx] = { ...r, id: state.recipes[existIdx].id };
      replaced++;
    } else {
      state.recipes.push({ ...r, id: Date.now() + Math.random() });
      added++;
    }
  });

  closeImportModal();
  saveState();

  const parts = [];
  if (added) parts.push(`${added} ajoutée${added>1?'s':''}`);
  if (replaced) parts.push(`${replaced} mise${replaced>1?'s':''} à jour`);
  toast(parts.join(', ') + ' ✓');
}

function closeImportModal() {
  const el = document.getElementById('import-modal');
  if (el) el.remove();
}


function init() {
  loadState();
  cancelEdit();
  render();
}

init();
</script>
